---
import PortableText from '../PortableText.astro'

interface Props {
  section: any
  headingLevel: string
}

const { section, headingLevel } = Astro.props
const HeadingTag = headingLevel as any
const items = section.items || []
---

<section class="acc-section">
  <div class="acc-section__container">
    {section.heading && (
      <HeadingTag class="acc-section__heading">{section.heading}</HeadingTag>
    )}
    {section.subtitle && (
      <p class="acc-section__subtitle">{section.subtitle}</p>
    )}
    <div class="acc-section__list">
      {items.map((item: any) => (
        <details class="acc-section__item" data-key={item._key}>
          <summary class="acc-section__question">{item.question}</summary>
          <div class="acc-section__answer">
            {item.answer && <PortableText value={item.answer} />}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .acc-section {
    padding: var(--space-16) var(--container-padding);
    background-color: #ffffff;
  }

  .acc-section__container {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .acc-section__heading {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-3xl);
    color: var(--navy-900);
    text-align: center;
    margin: 0 0 var(--space-4);
  }

  .acc-section__subtitle {
    font-family: var(--font-family-sans);
    font-size: var(--font-size-lg);
    color: var(--neutral-new-600);
    text-align: center;
    max-width: 55ch;
    margin: 0 auto var(--space-10);
    line-height: var(--line-height-relaxed);
  }

  .acc-section__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .acc-section__item {
    border: 1px solid var(--neutral-new-200);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: border-color 200ms ease;
  }

  .acc-section__item[open] {
    border-color: var(--gold-300);
  }

  .acc-section__question {
    padding: var(--space-5) var(--space-6);
    font-family: var(--font-family-sans);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--navy-800);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .acc-section__question::-webkit-details-marker {
    display: none;
  }

  .acc-section__question::after {
    content: '+';
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-normal);
    color: var(--gold-500);
    flex-shrink: 0;
    margin-left: var(--space-4);
    transition: transform 200ms ease;
  }

  .acc-section__item[open] .acc-section__question::after {
    content: '−';
  }

  .acc-section__question:hover {
    color: var(--navy-900);
    background-color: var(--neutral-new-50);
  }

  .acc-section__answer {
    padding: 0 var(--space-6) var(--space-6);
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--neutral-new-700);
  }

  .acc-section__answer :global(p) {
    margin: 0 0 var(--space-3);
  }

  .acc-section__answer :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (min-width: 48rem) {
    .acc-section__question {
      font-size: var(--font-size-lg);
    }
  }
</style>
