---
/**
 * NewsCard - Shared news article card component
 *
 * Used on homepage (top 3) and news listing page.
 * Accepts a news article object from Sanity GROQ query.
 */
import { urlFor, hotspotToPosition } from '../sanity/lib/image';

interface Props {
  article: {
    title: string;
    slug?: { current: string };
    date?: string;
    summary?: string;
    featured?: boolean;
    image?: any;
  };
}

const { article } = Astro.props;
---

<article class="news-card">
  <div class="news-card__image-wrapper">
    {article.image ? (
      <img
        src={urlFor(article.image).width(800).auto('format').url()}
        alt={article.image.alt || article.title}
        width="600"
        height="400"
        class="news-card__image"
        style={`object-position: ${hotspotToPosition(article.image.hotspot)}`}
        loading="lazy"
      />
    ) : (
      <div class="news-card__image-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
          <path d="M18 14h-8"/>
          <path d="M15 18h-5"/>
          <path d="M10 6h8v4h-8V6Z"/>
        </svg>
      </div>
    )}
  </div>
  <div class="news-card__content">
    <div class="news-card__meta">
      {article.date && (
        <time datetime={article.date} class="news-card__date">
          {new Date(article.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      )}
      {article.featured && (
        <span class="news-card__badge">Featured</span>
      )}
    </div>
    <h3 class="news-card__title">
      <a href={`/news/${article.slug?.current}`} class="news-card__link">
        {article.title}
      </a>
    </h3>
    {article.summary && (
      <p class="news-card__summary">{article.summary}</p>
    )}
  </div>
</article>

<style>
  .news-card {
    display: flex;
    flex-direction: column;
    background: var(--color-background);
    border: 1px solid var(--neutral-new-200);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: transform 300ms ease-out, box-shadow 300ms ease-out;
  }

  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }

  .news-card__image-wrapper {
    aspect-ratio: var(--aspect-card);
    overflow: hidden;
    background-color: var(--neutral-new-100);
  }

  .news-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease-out;
  }

  .news-card:hover .news-card__image {
    transform: scale(1.04);
  }

  .news-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--navy-800) 0%, var(--navy-700) 100%);
    color: rgba(255, 255, 255, 0.25);
  }

  .news-card__content {
    padding: var(--space-5);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .news-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-family: var(--font-family-sans);
    font-size: var(--font-size-sm);
  }

  .news-card__date {
    color: var(--color-text-muted);
  }

  .news-card__badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    background-color: var(--gold-500);
    color: var(--navy-900);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--border-radius-sm);
  }

  .news-card__title {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-snug);
    margin-bottom: var(--space-2);
    margin-top: 0;
  }

  .news-card__link {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .news-card__link:hover {
    color: var(--color-link);
  }

  .news-card__link:visited {
    color: var(--color-text-primary);
  }

  .news-card__summary {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-top: auto;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
