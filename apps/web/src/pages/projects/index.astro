---
/**
 * Student Projects — Public Showcase
 * Displays curated, published student projects with images and summaries.
 * SSR: content updates immediately when editors publish in Sanity.
 *
 * INTENTIONALLY DISABLED — ADR-019 (decisions.md)
 * /projects is Phase 2, held until AI Creator Lab produces showcase-ready work.
 * Re-enable: delete the early return below + the matching one in [id].astro.
 * Failing tests against /projects are expected, not a regression.
 */
export const prerender = false;

// ADR-019: intentionally offline — not a bug
return new Response('Not Found', { status: 404 });

import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { loadQuery } from '../../sanity/lib/load-query';
import { urlFor } from '../../sanity/lib/image';

const { data: projects } = await loadQuery<any[]>({
  query: `*[_type == "studentProject" && visibility == "Public"] | order(_createdAt desc) {
    _id,
    title,
    slug,
    summary,
    status,
    year,
    featuredImage,
    "studentName": student->name
  }`,
});

// Hardcoded hero image — TODO: move to CMS
const projHeroImage = {
  asset: { _ref: 'image-7e8c8210655fa8a5d63332a2be4eb93fcb1dc2dd-4508x1796-jpg' },
  alt: 'SCA student projects',
};
---

<BaseLayout title="Student Projects" containerClass="projects-layout">
  <PageHero image={projHeroImage}>
    <h1 class="proj-header__title">Student Projects</h1>
    <p class="proj-header__intro">
      Explore student-led projects from across Springfield Commonwealth Academy.
    </p>
  </PageHero>

  <div class="proj-listing__container">
    {projects.length === 0 ? (
      <p class="proj-listing__empty">No projects found.</p>
    ) : (
      <div class="proj-listing__grid">
        {projects.map((project: any) => (
          <a href={`/projects/${project.slug?.current || project._id}`} class="proj-card">
            {project.featuredImage?.asset && (
              <img
                src={urlFor(project.featuredImage).width(600).height(400).auto('format').url()}
                alt={project.title}
                class="proj-card__image"
                loading="lazy"
              />
            )}
            <div class="proj-card__content">
              <h3 class="proj-card__title">{project.title || 'Untitled'}</h3>
              {project.summary && (
                <p class="proj-card__summary">{project.summary}</p>
              )}
              <div class="proj-card__meta-row">
                {project.studentName && <span class="proj-card__meta">{project.studentName}</span>}
                {project.year && <span class="proj-card__meta">{project.year}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  @import '../../styles/global.css';

  :global(.main-content:has(.projects-layout)) {
    padding: 0;
  }

  /* Hero layout handled by PageHero component */

  .proj-header__title {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-4xl);
    color: #ffffff;
    margin: 0 0 var(--space-4);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .proj-header__intro {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.9);
    max-width: 50ch;
    margin: 0 auto;
    line-height: var(--line-height-relaxed);
  }

  @media (min-width: 48rem) {
    .proj-header {
      padding: var(--space-24) var(--container-padding) var(--space-14);
      min-height: 400px;
    }
    .proj-header__title {
      font-size: var(--font-size-5xl);
    }
  }

  /* Listing grid */
  .proj-listing__container {
    max-width: var(--max-width-full);
    margin: 0 auto;
    padding: var(--space-12) var(--container-padding);
  }

  .proj-listing__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 40rem) {
    .proj-listing__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .proj-listing__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .proj-listing__empty {
    text-align: center;
    color: var(--neutral-new-500);
    padding: var(--space-12) 0;
  }

  /* Project cards */
  .proj-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid var(--neutral-new-200);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 300ms ease-out, box-shadow 300ms ease-out, border-color 300ms ease-out;
  }

  .proj-card:visited {
    color: inherit;
  }

  .proj-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--gold-300);
  }

  .proj-card__image {
    width: 100%;
    aspect-ratio: var(--aspect-card);
    object-fit: cover;
  }

  .proj-card__content {
    padding: var(--space-4) var(--space-5) var(--space-5);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .proj-card__title {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-lg);
    color: var(--navy-800);
    margin: 0 0 var(--space-2);
    line-height: var(--line-height-snug);
  }

  .proj-card__summary {
    font-size: var(--font-size-sm);
    color: var(--neutral-new-600);
    line-height: var(--line-height-relaxed);
    margin: 0 0 var(--space-3);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .proj-card__meta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .proj-card__meta {
    font-family: var(--font-family-sans);
    font-size: var(--font-size-xs);
    color: var(--neutral-new-600);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
</style>
