    rendererPath: 'apps/web/src/components/sections/LatestNews.astro',
    registeredOn: ['page', 'homepageConfig'],
    schemaExcerpt: `name: 'latestNews',
fields: [
  defineField({ name: 'heading', initialValue: 'Latest News' }),
  defineField({ name: 'limit', type: 'number', initialValue: 3,
    validation: r => r.required().integer().min(1).max(12) }),
  defineField({ name: 'ctaLabel', initialValue: 'View All News' }),
  defineField({ name: 'ctaHref', initialValue: '/news' }),
]`,
    rendererExcerpt: `const { data: news } = await loadQuery({
  query: \`*[_type=="news"] | order(featured desc, date desc)[0...$\{limit}]\`
})
{news.map(article => <NewsCard article={article} />)}`,
    notes: 'Self-fetches from Sanity. Not registered on program documents.',
  },
  {
    id: 'video-embed',
    label: 'Video Embed',
    tagline: 'External YouTube or Vimeo video. Editor pastes a URL.',
    Component: VideoEmbed,
    sample: {
      _type: 'videoEmbed',
      _key: 'demo-video',
      url: 'https://www.youtube.com/watch?v=vKKK098we_I',
      title: 'Demo video',
      caption: 'Sample caption — replace with editorial copy in production.',
      aspectRatio: '16/9',
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/videoEmbed.ts',
    rendererPath: 'apps/web/src/components/sections/VideoEmbed.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'videoEmbed',
fields: [
  defineField({ name: 'url', type: 'url',
    validation: r => r.required().custom(v => {
      const r = parseVideoEmbed(v)
      return 'error' in r ? r.error : true
    }) }),
  defineField({ name: 'title', type: 'string' }),
  defineField({ name: 'caption', type: 'string' }),
  defineField({ name: 'aspectRatio', type: 'string',
    options: { list: ['16/9', '9/16', '4/3'] } }),
]`,
    rendererExcerpt: `const parsed = parseVideoEmbed(section.url)
const embedSrc = 'src' in parsed ? parsed.src : null
{embedSrc && (
  <iframe src={embedSrc} loading="lazy" allowfullscreen
    referrerpolicy="strict-origin-when-cross-origin" />
)}`,
    notes:
      'YouTube uses youtube-nocookie.com, which reduces tracking compared with the standard embed domain. The iframe is loading="lazy" and the URL is allowlisted at the schema level.',
  },
]
---

<BaseLayout
  title="Block Library"
  description="Internal reference page showing every page-builder block with sample data and developer notes."
  containerClass="bl-layout"
  noindex
>
  <header class="bl-header">
    <p class="bl-header__eyebrow">Internal reference</p>
    <h1 class="bl-header__title">Block Library</h1>
    <p class="bl-header__lede">
      Every page-builder block on a single page, rendered with sample data. Open the
      <strong>Developer details</strong> panel under each block to see file paths, sample
      payloads, and short illustrative excerpts of the schema and renderer.
    </p>
    <p class="bl-header__access">
      <strong>Access posture:</strong> this page is <code>noindex</code>, but the URL is not
      access control. Anyone with the link can view this page. Full source code lives in the
      repository, not here.
    </p>
  </header>

  <nav class="bl-toc" aria-label="Block library contents">
    <p class="bl-toc__label">Blocks</p>
    <ol class="bl-toc__list">
      {blocks.map((b, i) => (
        <li><a href={`#${b.id}`}>{i + 1}. {b.label}</a></li>
      ))}
    </ol>
  </nav>

  {blocks.map((b, i) => (
    <section id={b.id} class="bl-block">
      <header class="bl-block__head">
        <p class="bl-block__num">Block {i + 1} of {blocks.length}</p>
        <h2 class="bl-block__title">{b.label}</h2>
        <p class="bl-block__tagline">{b.tagline}</p>
      </header>

      <div class="bl-block__live">
        <b.Component section={b.sample} headingLevel="h3" />
      </div>

      <details class="bl-block__dev">
        <summary>Developer details</summary>
        <dl class="bl-dl">
          <dt>Schema file</dt>
          <dd><code>{b.schemaPath}</code></dd>
          <dt>Renderer file</dt>
          <dd><code>{b.rendererPath}</code></dd>
          <dt>Allowed on document types</dt>
          <dd>{b.registeredOn.join(', ')}</dd>
          {b.notes && (<><dt>Notes</dt><dd>{b.notes}</dd></>)}
          <dt>Sample payload (passed to the renderer as the <code>section</code> prop)</dt>
          <dd><pre class="bl-code"><code>{JSON.stringify(b.sample, null, 2)}</code></pre></dd>
          <dt>Schema excerpt (illustrative — not full source)</dt>
          <dd><pre class="bl-code"><code>{b.schemaExcerpt}</code></pre></dd>
          <dt>Renderer excerpt (illustrative — not full source)</dt>
          <dd><pre class="bl-code"><code>{b.rendererExcerpt}</code></pre></dd>
        </dl>
      </details>
    </section>
  ))}

  <section class="bl-howto">
    <h2>How to add a new block</h2>
    <ol>
      <li>Create the schema at <code>apps/sca-studio/schemaTypes/blocks/&lt;name&gt;.ts</code>.</li>
      <li>Register it in <code>apps/sca-studio/schemaTypes/index.ts</code>.</li>
      <li>Add it to the <code>sections[].of</code> array on each document type that should accept it (<code>page.ts</code>, <code>program.ts</code>, <code>homepageConfig.ts</code>).</li>
      <li>Create the renderer at <code>apps/web/src/components/sections/&lt;Name&gt;.astro</code> and register it in <code>SectionRenderer.astro</code>'s <code>SECTION_MAP</code>.</li>
    </ol>

    <h2>How reskinning works</h2>
    <p>The site separates <em>what content exists</em> from <em>how content looks</em>. There are three layers:</p>
    <ol>
      <li>
        <strong>Sitewide design tokens</strong> live in <code>apps/web/src/styles/global.css</code> and theme files in <code>apps/web/src/styles/themes/</code>. Changing token values (colors, spacing, fonts) propagates through every block.
      </li>
      <li>
        <strong>Per-block visuals</strong> live in each block's <code>.astro</code> file. Each block contains its own scoped CSS. Changing one block does not affect any other.
      </li>
      <li>
        <strong>Editor controls</strong> are confined to schema-defined fields: text content, image choice, block ordering, and a small number of variant options (e.g. CTA banner color, video aspect ratio). Editors cannot change CSS, HTML structure, or layout.
      </li>
    </ol>
    <p>A future re-skin can range from changing token values (light) to adding a new theme file with per-block variants (heavier). Editors do not need to relearn anything either way.</p>
  </section>
</BaseLayout>

<style>
  :global(.bl-layout) {
    max-width: var(--max-width-full);
    margin: 0 auto;
    padding: var(--space-12) var(--container-padding) var(--space-24);
  }

  .bl-header {
    margin: 0 0 var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--neutral-new-200, #e5e7eb);
  }

  .bl-header__eyebrow {
    font-family: var(--font-family-sans);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold-500);
    margin: 0 0 var(--space-3);
  }

  .bl-header__title {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-5xl);
    margin: 0 0 var(--space-4);
  }

  .bl-header__lede {
    font-size: var(--font-size-lg);
    max-width: 60ch;
    margin: 0 0 var(--space-4);
    color: var(--neutral-new-700, #374151);
  }

  .bl-header__access {
    font-size: var(--font-size-sm);
    max-width: 60ch;
    color: var(--neutral-new-600);
    background: var(--neutral-new-50);
    padding: var(--space-3) var(--space-4);
    border-left: 3px solid var(--gold-500);
