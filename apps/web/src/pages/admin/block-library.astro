))}`,
  },
  {
    id: 'upcoming-events',
    label: 'Upcoming Events',
    tagline: 'Auto-populated list of upcoming events from the CMS, sorted by date.',
    Component: UpcomingEvents,
    sample: {
      _type: 'upcomingEvents',
      _key: 'demo-events',
      heading: 'Upcoming Events',
      limit: 4,
