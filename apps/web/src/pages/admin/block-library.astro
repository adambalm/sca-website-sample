    schemaPath: 'apps/sca-studio/schemaTypes/blocks/upcomingEvents.ts',
    rendererPath: 'apps/web/src/components/sections/UpcomingEvents.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'upcomingEvents',
fields: [
  defineField({ name: 'heading', type: 'string', initialValue: 'Upcoming Events' }),
  defineField({ name: 'limit', type: 'number', initialValue: 3,
    validation: r => r.required().integer().min(1).max(12) }),
]`,
    rendererExcerpt: `const { data: events } = await loadQuery({
  query: \`*[_type=="event" && date >= now()] | order(date asc)[0...$\{limit}]\`
})
{events.map(e => <EventCard event={e} />)}`,
    notes: 'Self-fetches from Sanity at render time. Shows real published events.',
