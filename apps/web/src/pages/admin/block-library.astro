---
/**
 * Block Library — internal reference page (NOT authenticated).
 *
 * Demonstrates every page-builder section block on a single page with a
 * realistic sample payload, file paths, and short illustrative excerpts.
 * The URL is noindex but the page is reachable by anyone with the link;
 * full schema/renderer source code is intentionally not rendered here.
 */
export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/sections/HeroSection.astro'
import TextWithImage from '../../components/sections/TextWithImage.astro'
import CardGrid from '../../components/sections/CardGrid.astro'
import CtaBanner from '../../components/sections/CtaBanner.astro'
import RichTextSection from '../../components/sections/RichTextSection.astro'
import StatsRow from '../../components/sections/StatsRow.astro'
import TestimonialBlock from '../../components/sections/TestimonialBlock.astro'
import AccordionSection from '../../components/sections/AccordionSection.astro'
import UpcomingEvents from '../../components/sections/UpcomingEvents.astro'
import LatestNews from '../../components/sections/LatestNews.astro'
import VideoEmbed from '../../components/sections/VideoEmbed.astro'

interface BlockEntry {
  id: string
  label: string
  tagline: string
  Component: any
  sample: any
  schemaPath: string
  rendererPath: string
  registeredOn: string[]
  schemaExcerpt: string
  rendererExcerpt: string
  notes?: string
}

const blocks: BlockEntry[] = [
  {
    id: 'hero-section',
    label: 'Hero Section',
    tagline: 'Full-bleed page header with optional eyebrow, heading, subtitle, and CTAs.',
    Component: HeroSection,
    sample: {
      _type: 'heroSection',
      _key: 'demo-hero',
      eyebrow: 'Welcome',
      heading: 'Discover Academic Excellence',
      subtitle:
        'A demonstration hero with no Sanity image attached — production heroes use the school’s photography library.',
      overlayOpacity: 40,
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/heroSection.ts',
    rendererPath: 'apps/web/src/components/sections/HeroSection.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'heroSection',
fields: [
  defineField({ name: 'eyebrow', type: 'string' }),
  defineField({ name: 'heading', type: 'string', validation: r => r.required() }),
  defineField({ name: 'subtitle', type: 'text' }),
  defineField({ name: 'image', type: 'image', options: { hotspot: true } }),
  defineField({ name: 'primaryCta', type: 'object', fields: [...] }),
]`,
    rendererExcerpt: `<PageHero image={section.image} overlayOpacity={opacity}>
  {section.eyebrow && <p class="hero-section__eyebrow">{section.eyebrow}</p>}
  <HeadingTag class="hero-section__heading">{section.heading}</HeadingTag>
  {section.subtitle && <p class="hero-section__subtitle">{section.subtitle}</p>}
</PageHero>`,
    notes: 'First heroSection on a page receives <h1>; subsequent headings use <h2>.',
  },
  {
    id: 'rich-text',
    label: 'Rich Text',
    tagline: 'Long-form prose. Editor formats with bold, italic, links, lists, headings.',
    Component: RichTextSection,
    sample: {
      _type: 'richText',
      _key: 'demo-richtext',
      heading: 'About Springfield Commonwealth',
      maxWidth: 'narrow',
      content: [
        {
          _type: 'block',
          _key: 'p1',
          style: 'normal',
          children: [
            {
              _type: 'span',
              _key: 's1',
              text: 'This is a sample rich-text block. In production, an editor types this paragraph in the Sanity Studio with a familiar formatting toolbar — bold, italic, links, headings, and bullet lists.',
            },
          ],
        },
        {
          _type: 'block',
          _key: 'p2',
          style: 'normal',
          children: [
            {
              _type: 'span',
              _key: 's2',
              text: 'The Width control on this block lets editors choose a narrow column for readability or a wide column for reference content.',
            },
          ],
        },
      ],
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/richText.ts',
    rendererPath: 'apps/web/src/components/sections/RichTextSection.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'richText',
fields: [
  defineField({ name: 'heading', type: 'string' }),
  defineField({ name: 'maxWidth', type: 'string',
    options: { list: ['narrow', 'wide', 'full'] } }),
  defineField({ name: 'content', type: 'array',
    of: [{ type: 'block' }] }),
]`,
    rendererExcerpt: `<section class={['rt-section', widthClass]}>
  {section.heading && <HeadingTag>{section.heading}</HeadingTag>}
  {section.content && <PortableText value={section.content} />}
</section>`,
  },
  {
    id: 'card-grid',
    label: 'Card Grid',
    tagline: 'Responsive grid of cards. Each card has an icon or image, title, body, and optional link.',
    Component: CardGrid,
    sample: {
      _type: 'cardGrid',
      _key: 'demo-cards',
      heading: 'What Makes SCA Different',
      subtitle: 'Three pillars editors can rearrange, retitle, or extend without writing code.',
      columns: 3,
      cards: [
        {
          _key: 'c1',
          title: 'Academic Rigor',
          body: 'Small classes, demanding curriculum, and one-on-one mentorship.',
          icon: 'brain',
        },
        {
          _key: 'c2',
          title: 'Boarding Community',
          body: 'A residential life that builds independence and lifelong friendships.',
          icon: 'users',
        },
        {
          _key: 'c3',
          title: 'Athletics That Matter',
          body: 'Competitive teams, coaching from former collegiate athletes.',
          icon: 'trophy',
        },
      ],
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/cardGrid.ts',
    rendererPath: 'apps/web/src/components/sections/CardGrid.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'cardGrid',
fields: [
  defineField({ name: 'heading', type: 'string' }),
  defineField({ name: 'columns', type: 'number',
    options: { list: [2, 3, 4] }, initialValue: 3 }),
  defineField({ name: 'cards', type: 'array', of: [
    defineArrayMember({ type: 'object', fields: [
      'title', 'body', 'image', 'icon', 'link',
    ] })
  ] }),
]`,
    rendererExcerpt: `<div class="cg-section__grid">
  {cards.map(card => (
    <article class="cg-card">
      {card.image?.asset && <img src={urlFor(card.image)…} />}
      <h3>{card.title}</h3>
      <p>{card.body}</p>
    </article>
  ))}
</div>`,
    notes: 'Image fields omitted in this sample. Editors choose images from the Sanity asset library; the renderer calls urlFor() and serves responsive variants.',
  },
  {
    id: 'text-with-image',
    label: 'Text with Image',
    tagline: 'Image on one side, text on the other. Editor chooses left/right and standard/portrait layout.',
    Component: TextWithImage,
    sample: {
      _type: 'textWithImage',
      _key: 'demo-twi',
      heading: 'Where Boarding and Day Students Learn Together',
      orientation: 'imageRight',
      layout: 'standard',
      content: [
        {
          _type: 'block',
          _key: 'p1',
          children: [
            {
              _type: 'span',
              _key: 's1',
              text: 'A demonstration block with no image attached so the layout reflows to a single column. In production, editors pick an image from the asset library; the schema enforces alt text for accessibility.',
            },
          ],
        },
      ],
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/textWithImage.ts',
    rendererPath: 'apps/web/src/components/sections/TextWithImage.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'textWithImage',
fields: [
  defineField({ name: 'heading', type: 'string' }),
  defineField({ name: 'orientation', type: 'string',
    options: { list: ['imageLeft', 'imageRight'] } }),
  defineField({ name: 'layout', type: 'string',
    options: { list: ['standard', 'portrait'] } }),
  defineField({ name: 'image', type: 'image' }),
  defineField({ name: 'content', type: 'array', of: [{ type: 'block' }] }),
]`,
    rendererExcerpt: `<section class={['twi-section', \`twi-section--\${orientation}\`]}>
  {hasImage && <img src={urlFor(section.image)…} />}
  <div class="twi-section__text">
    <HeadingTag>{section.heading}</HeadingTag>
    <PortableText value={section.content} />
  </div>
</section>`,
  },
  {
    id: 'cta-banner',
    label: 'CTA Banner',
    tagline: 'Call-to-action panel with heading, optional subtitle, and one or two buttons.',
    Component: CtaBanner,
    sample: {
      _type: 'ctaBanner',
      _key: 'demo-cta',
      heading: 'Ready to Visit?',
      subtitle: 'Schedule a campus tour or request more information.',
      variant: 'navy',
      primaryCta: { label: 'Schedule a Tour', href: '/contact' },
      secondaryCta: { label: 'Request Info', href: '/admissions' },
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/ctaBanner.ts',
    rendererPath: 'apps/web/src/components/sections/CtaBanner.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'ctaBanner',
fields: [
  defineField({ name: 'heading', type: 'string', validation: r => r.required() }),
  defineField({ name: 'subtitle', type: 'string' }),
  defineField({ name: 'variant', type: 'string',
    options: { list: ['navy', 'gold', 'light'] } }),
  defineField({ name: 'primaryCta', type: 'object',
    fields: [{ name: 'label' }, { name: 'href' }] }),
]`,
    rendererExcerpt: `<section class={['cta-banner', \`cta-banner--\${variant}\`]}>
  <HeadingTag>{section.heading}</HeadingTag>
  {section.subtitle && <p>{section.subtitle}</p>}
  <a href={section.primaryCta.href} class="btn btn--primary">{section.primaryCta.label}</a>
</section>`,
  },
  {
    id: 'stats-row',
    label: 'Stats Row',
    tagline: 'Row of numerical highlights. Each stat has a value and a label.',
    Component: StatsRow,
    sample: {
      _type: 'statsRow',
      _key: 'demo-stats',
      heading: 'By the Numbers',
      variant: 'navy',
      stats: [
        { _key: 's1', value: '8:1', label: 'Student–faculty ratio' },
        { _key: 's2', value: '24', label: 'AP & advanced courses' },
        { _key: 's3', value: '100%', label: 'College placement' },
        { _key: 's4', value: '32', label: 'Athletic teams' },
      ],
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/statsRow.ts',
    rendererPath: 'apps/web/src/components/sections/StatsRow.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'statsRow',
fields: [
  defineField({ name: 'heading', type: 'string' }),
  defineField({ name: 'variant', type: 'string',
    options: { list: ['navy', 'gold', 'light'] } }),
  defineField({ name: 'stats', type: 'array', of: [
    defineArrayMember({ type: 'object',
      fields: [{ name: 'value' }, { name: 'label' }] })
  ] }),
]`,
    rendererExcerpt: `<div class="sr-section__grid">
  {stats.map(s => (
    <div class="sr-section__item">
      <span class="sr-section__value">{s.value}</span>
      <span class="sr-section__label">{s.label}</span>
    </div>
  ))}
</div>`,
  },
  {
    id: 'testimonial-block',
    label: 'Testimonial',
    tagline: 'Pull quote with attribution and optional photo.',
    Component: TestimonialBlock,
    sample: {
      _type: 'testimonialBlock',
      _key: 'demo-testimonial',
      quote:
        'The teachers know my daughter as a person, not just a name on a roster. That changed everything for her.',
      name: 'Demo Parent',
      role: 'Parent of a current student',
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/testimonialBlock.ts',
    rendererPath: 'apps/web/src/components/sections/TestimonialBlock.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'testimonialBlock',
fields: [
  defineField({ name: 'quote', type: 'text', validation: r => r.required() }),
  defineField({ name: 'name', type: 'string' }),
  defineField({ name: 'role', type: 'string' }),
  defineField({ name: 'image', type: 'image', options: { hotspot: true } }),
]`,
    rendererExcerpt: `<blockquote>
  <p>&ldquo;{section.quote}&rdquo;</p>
</blockquote>
<cite>{section.name}</cite>
{section.role && <p>{section.role}</p>}`,
    notes: 'Quoted person and role above are illustrative — not real attributions.',
  },
  {
    id: 'accordion-section',
    label: 'Accordion (FAQ)',
    tagline: 'Expandable Q&A list. Each item has a question and a rich-text answer.',
    Component: AccordionSection,
    sample: {
      _type: 'accordionSection',
      _key: 'demo-accordion',
      heading: 'Frequently Asked Questions',
      items: [
        {
          _key: 'q1',
          question: 'Do you offer financial aid?',
          answer: [
            {
              _type: 'block',
              _key: 'a1',
              children: [
                {
                  _type: 'span',
                  _key: 's1',
                  text: 'Yes. Sample answer text — in production this is full rich text.',
                },
              ],
            },
          ],
        },
        {
          _key: 'q2',
          question: 'When are tours offered?',
          answer: [
            {
