                },
              ],
            },
          ],
        },
        {
          _key: 'q3',
          question: 'What is the student–faculty ratio?',
          answer: [
            {
              _type: 'block',
              _key: 'a3',
              children: [{ _type: 'span', _key: 's3', text: 'Sample answer: 8:1.' }],
            },
          ],
        },
      ],
    },
    schemaPath: 'apps/sca-studio/schemaTypes/blocks/accordionSection.ts',
    rendererPath: 'apps/web/src/components/sections/AccordionSection.astro',
    registeredOn: ['page', 'program', 'homepageConfig'],
    schemaExcerpt: `name: 'accordionSection',
fields: [
  defineField({ name: 'heading', type: 'string' }),
  defineField({ name: 'items', type: 'array', of: [
    defineArrayMember({ type: 'object', fields: [
      { name: 'question', type: 'string' },
      { name: 'answer', type: 'array', of: [{ type: 'block' }] },
